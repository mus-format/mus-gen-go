{{/* data.TypeData */}}
{{- $v := Ser.Val . }}
{{- $fulp := Tmpl.UnmarshalLastParam true .Gops }}
{{- $ulp := Tmpl.UnmarshalLastParam false .Gops }}
dtm, n, err := typed.DTMSer.Unmarshal({{ $fulp }})
if err != nil {
	return
}
var n1 int
switch dtm {
{{- range $e := .Impls }}
	case {{ Ser.DTMVar $e }}:
		{{ $v }}, n1, err = {{ Ser.TypedVar $e }}.UnmarshalData({{ $ulp }})
{{- end }}
	default:
		err = com.NewUnexpectedDTMError(dtm)
		return
}
n += n1
return
