{{/* spec.VersionedType */}}
{{- $v := Ser.Val . }}
{{- $fulp := Tmpl.UnmarshalLastParam true .Gops }}
{{- $ulp := Tmpl.UnmarshalLastParam false .Gops }}
dtm, n, err := typed.DTMSer.Unmarshal({{ $fulp }})
if err != nil {
	return
}
var n1 int
switch dtm {
{{- range $i, $e := .Versions }}
    {{- $vopt := index $.Vops.Versions $i }}
	case {{ Ser.DTMVar $e }}:
		var tmp {{ Ser.RelName $e }}
		tmp, n1, err = {{ Ser.TypedVar $e }}.UnmarshalData({{ $ulp }})
		if err != nil {
			return
		}
        {{- if ne $vopt.Migration "" }}
		{{ $v }} = {{ $vopt.Migration }}(tmp)
        {{- else }}
		{{ $v }} = {{ Ser.RelName $.FullName }}(tmp)
        {{- end }}
{{- end }}
	default:
		err = com.NewUnexpectedDTMError(dtm)
		return
}
n += n1
return